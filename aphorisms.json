[
  {
    "Id": "4e062233-8f33-47c1-959e-cdebc99d993e",
    "Text": "\u041D\u0435 \u0432\u0456\u0434\u043A\u043B\u0430\u0434\u0430\u0439 \u043D\u0430 \u0437\u0430\u0432\u0442\u0440\u0430 \u0442\u0435, \u0449\u043E \u043C\u043E\u0436\u043D\u0430 \u0437\u0440\u043E\u0431\u0438\u0442\u0438 \u0441\u044C\u043E\u0433\u043E\u0434\u043D\u0456.",
